{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*", "src/**/*.vue"],
  "exclude": ["src/views/_dev/**"],
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "lib": ["ES2021.String", "ES2020", "ES2022.Object", "ES2023.Array", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
